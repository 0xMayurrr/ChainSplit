# ChainSplit — Environment Variables
# Copy this to .env and fill in your values

# Your deployer wallet private key (NO 0x prefix)
PRIVATE_KEY=your_private_key_here

# Cronos RPC URLs
CRONOS_TESTNET_RPC=https://evm-t3.cronos.org
CRONOS_MAINNET_RPC=https://evm.cronos.org

# After deployment, paste contract addresses here
CHAINSPLIT_FACTORY_ADDRESS=

# Frontend env (copy to frontend/.env)
VITE_FACTORY_ADDRESS=
VITE_CRONOS_TESTNET_RPC=https://evm-t3.cronos.org
VITE_CHAIN_ID=338
