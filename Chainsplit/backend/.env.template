PORT=3000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/chainsplit?retryWrites=true&w=majority

# Network: "testnet" or "mainnet"
NETWORK=testnet

# Cronos RPC
CRONOS_TESTNET_RPC_URL=https://evm-t3.cronos.org
CRONOS_RPC_URL=https://evm.cronos.org

# Factory addresses
FACTORY_ADDRESS=0xe9256300bb409b5Cf8CF16aDD6A0aDB0cc72E5bf
FACTORY_ADDRESS_MAINNET=<your_mainnet_factory_address>

# Pinata IPFS
PINATA_API_KEY=<your_pinata_api_key>
PINATA_API_SECRET=<your_pinata_api_secret>
PINATA_JWT=<your_pinata_jwt>

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL=https://chainsplit.vercel.app
